<?xml version="1.0"?>
<!--
  ft45_sensor.xacro
  ==================
  Macro XACRO del sensor de fuerza/torque Schunk FT45-1009 (= ATI Mini45).

  Dimensiones reales (datasheet ATI Mini45):
    - Diámetro: 45 mm  → radio: 0.0225 m
    - Altura total: 16.5 mm → 0.0165 m
    - Masa: ~92 g → 0.092 kg
    - Inercias calculadas para un cilindro sólido:
        Ixx = Iyy = (1/12)*m*(3r²+h²) = (1/12)*0.092*(3*0.0225²+0.0165²) ≈ 1.68e-5
        Izz = (1/2)*m*r²             = (1/2)*0.092*0.0225²             ≈ 2.33e-5

  Rangos de medida (FT45-1009 / Mini45-SI-580-20):
    Fx,Fy: ±580 N    Fz: ±1160 N
    Mx,My: ±20 Nm    Mz: ±20 Nm

  Uso:
    <xacro:include filename="$(find iiwa_ft_sensor)/urdf/ft45_sensor.xacro"/>
    <xacro:ft45_sensor
        parent="iiwa_link_7"
        prefix="ft45"
        xyz="0 0 0"
        rpy="0 0 0"/>

  Topics publicados (plugin Gazebo):
    /ft45/wrench  [geometry_msgs/WrenchStamped]
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- macro principal del sensor de fuerza ft45-->
  <xacro:macro name="ft45_sensor"
               params="parent prefix xyz:='0 0 0' rpy:='0 0 0'
                       update_rate:='1000'
                       noise_stddev_force:='0.01'
                       noise_stddev_torque:='0.001'">
    <!-- link cilindrillo representativo-->
    <link name="${prefix}_link">
      <visual>
        <geometry>
          <!-- Cilindro representativo. Sustituir por mesh si se dispone
               de un archivo .dae/.stl del ATI Mini45 -->
          <cylinder radius="0.0225" length="0.0165"/>
        </geometry>
        <origin xyz="0 0 0.00825" rpy="0 0 0"/>
        <material name="ft45_silver">
          <color rgba="0.75 0.75 0.75 1.0"/>
        </material>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.0225" length="0.0165"/>
        </geometry>
        <origin xyz="0 0 0.00825" rpy="0 0 0"/>
      </collision>

      <inertial>
        <mass value="0.092"/>
        <origin xyz="0 0 0.00825" rpy="0 0 0"/>
        <inertia
          ixx="1.68e-5" ixy="0" ixz="0"
          iyy="1.68e-5" iyz="0"
          izz="2.33e-5"/>
      </inertial>
    </link>

    <!-- el link con el que se junta al botardo-->
    <joint name="${prefix}_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- con esto empieza a calcular correctamente es el punto de medida
     va en la cara inferior-->
    <link name="${prefix}_measuring_point">
      <inertial>
        <mass value="0.001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-9" ixy="0" ixz="0"
                 iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
    </link>

    <joint name="${prefix}_measuring_point_joint" type="fixed">
      <parent link="${prefix}_link"/>
      <child  link="${prefix}_measuring_point"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- plugin de gazebo que emula el sensor que tiene seis ejes
     publica geometry_msgs/WrenchStamped topic-->
    <gazebo reference="${prefix}_link">
      <sensor name="${prefix}_ft_sensor" type="force_torque">
        <always_on>true</always_on>
        <update_rate>${update_rate}</update_rate>
        <visualize>false</visualize>

        <force_torque>
          <frame>${prefix}_measuring_point</frame>
          <measure_direction>child_to_parent</measure_direction>
          <!-- Ruido gaussiano (modelo simplificado) -->
          <force>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_force}</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_force}</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_force}</stddev></noise></z>
          </force>
          <torque>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_torque}</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_torque}</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>${noise_stddev_torque}</stddev></noise></z>
          </torque>
        </force_torque>

        <plugin name="${prefix}_plugin" filename="libgazebo_ros_ft_sensor.so">
          <ros>
            <namespace></namespace>
            <remapping>wrench:=/${prefix}/wrench</remapping>
          </ros>
          <body_name>${prefix}_link</body_name>
          <joint_name>${prefix}_joint</joint_name>
          <frame_name>${prefix}_measuring_point</frame_name>
          <update_rate>${update_rate}</update_rate>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Apariencia Gazebo del cuerpo del sensor -->
    <gazebo reference="${prefix}_link">
      <material>Gazebo/Silver</material>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
    </gazebo>

  </xacro:macro>

</robot>
